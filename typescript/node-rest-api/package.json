{
  "name": "node-rest-api",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js REST API starter written in TypeScript.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "local": "ts-node src/local.ts",
    "test": "node -r ts-node/register --test \"src/**/*.test.ts\"",
    "create-types": "npx openapi-typescript@7.13.0 openapi.json -o src/schema.ts",
    "double-check": "npm run create-types && npm run build && npm run test",
    "db:build": "docker build -f src/db/Dockerfile -t postgres .",
    "db:run": "docker run --rm --name ${DB_CONTAINER_NAME:-node-rest-api-postgres} -p ${PGPORT:-5432}:5432 postgres"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dockerode": "^5.0.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "pg": "^8.20.0"
  }
}
